/* 页面样式 */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-item {
  margin-bottom: 30rpx;
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.form-label {
  display: block;
  margin-bottom: 15rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker {
  font-size: 30rpx;
  color: #666;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 30rpx;
  color: #666;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background-color: #1976D2;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  border-radius: 10rpx;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.3);
}

.submit-btn:hover {
  background-color: #1565C0;
}

.result {
  margin-top: 40rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.result-title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 15rpx;
}

.result-item {
  margin-bottom: 15rpx;
  font-size: 30rpx;
  color: #666;
  line-height: 1.5;
}

.gem-list {
  margin-top: 20rpx;
}

.gem-item {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  border-left: 6rpx solid #1976D2;
}

.gem-name {
  font-weight: bold;
  margin-right: 20rpx;
  color: #333;
  font-size: 30rpx;
  min-width: 120rpx;
}

.gem-effect {
  flex: 1;
  color: #666;
  font-size: 28rpx;
  line-height: 1.4;
}